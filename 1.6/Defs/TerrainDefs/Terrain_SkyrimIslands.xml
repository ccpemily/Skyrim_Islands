<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <TerrainDef ParentName="WaterDeepBase">
    <defName>SkyrimIslands_CloudSea</defName>
    <label>云海</label>
    <edgeType>Hard</edgeType>
    <renderPrecedence>300</renderPrecedence>
    <dontRender>true</dontRender>
    <spaceEdgeGraphicData IsNull="True" />
    <canBePolluted>false</canBePolluted>
    <waterBodyType>Freshwater</waterBodyType>
    <forcePassableByFlyingPawns>true</forcePassableByFlyingPawns>
  </TerrainDef>

  <TerrainDef ParentName="PlatformBase">
    <defName>SkyrimIslands_IslandCore</defName>
    <label>空岛核心</label>
    <texturePath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatform</texturePath>
    <fertility>0</fertility>
    <statBases>
      <Beauty>0</Beauty>
      <BeautyOutdoors>0</BeautyOutdoors>
      <Cleanliness>-0.1</Cleanliness>
    </statBases>
    <spaceEdgeGraphicData Inherit="False">
      <OShapeTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_OShape</OShapeTexPath>
      <UShapeTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_UShape</UShapeTexPath>
      <CornerInnerTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_CornerInner</CornerInnerTexPath>
      <CornerOuterTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_CornerOuter</CornerOuterTexPath>
      <FlatTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_Flat</FlatTexPath>
      <LoopLeftTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Left</LoopLeftTexPath>
      <LoopRightTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Right</LoopRightTexPath>
      <LoopSingleTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Single</LoopSingleTexPath>
      <LoopTexPaths>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop1</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop2</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop3</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop4</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop5</li>
      </LoopTexPaths>
    </spaceEdgeGraphicData>
  </TerrainDef>

  <TerrainDef ParentName="PlatformBase">
    <defName>SkyrimIslands_FloatingPlatform</defName>
    <label>浮空石平台</label>
    <texturePath>Terrain/Surfaces/SoilRich</texturePath>
    <fertility>1.4</fertility>
    <takeFootprints>true</takeFootprints>
    <generatedFilth>Filth_Dirt</generatedFilth>
    <statBases>
      <Beauty>-1</Beauty>
      <Cleanliness>0</Cleanliness>
    </statBases>
    <spaceEdgeGraphicData Inherit="False">
      <OShapeTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_OShape</OShapeTexPath>
      <UShapeTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_UShape</UShapeTexPath>
      <CornerInnerTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_CornerInner</CornerInnerTexPath>
      <CornerOuterTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_CornerOuter</CornerOuterTexPath>
      <FlatTexPath>Terrain/Surfaces/MechanoidPlatform/BorderInside/MechanoidPlatformBorderInside_Flat</FlatTexPath>
      <LoopLeftTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Left</LoopLeftTexPath>
      <LoopRightTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Right</LoopRightTexPath>
      <LoopSingleTexPath>Terrain/Surfaces/MechanoidPlatform/MechanoidPlatformEdge_Single</LoopSingleTexPath>
      <LoopTexPaths>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop1</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop2</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop3</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop4</li>
        <li>Terrain/Surfaces/MechanoidPlatform/Loop/MechanoidPlatformEdge_Loop5</li>
      </LoopTexPaths>
    </spaceEdgeGraphicData>
  </TerrainDef>

</Defs>
